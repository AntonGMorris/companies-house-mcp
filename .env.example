# Get one free at https://developer.company-information.service.gov.uk/
CH_API_KEY=your-companies-house-api-key-here

# Optional: override rate limit (defaults to CH's published 600 req / 5 min per key).
# CH_RATE_LIMIT_MAX=600
# CH_RATE_LIMIT_WINDOW_SECONDS=300

# Optional: cache TTL in seconds (default 300 = 5 min).
# CH_CACHE_TTL_SECONDS=300

# Optional: max cache entries before LRU eviction (default 1000).
# CH_CACHE_MAX_ENTRIES=1000
