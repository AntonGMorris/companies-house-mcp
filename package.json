{
  "name": "companies-house-mcp",
  "version": "0.1.0",
  "description": "Production-grade Model Context Protocol server for the UK Companies House API. Auth, rate limits, caching, tests.",
  "type": "module",
  "license": "MIT",
  "author": "Anton Morris",
  "repository": {
    "type": "git",
    "url": "https://github.com/shadowborn-dev/companies-house-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/shadowborn-dev/companies-house-mcp/issues"
  },
  "homepage": "https://github.com/shadowborn-dev/companies-house-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "companies-house",
    "uk",
    "kyc",
    "claude"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "companies-house-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
